rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 0: Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // UserStats Validation logic
    function isValidUserStats(data) {
      return data.keys().hasAll(['good', 'bad', 'xp', 'updatedAt']) 
             && data.good is number
             && data.bad is number
             && data.xp is number
             && (!('srs' in data) || data.srs is map)
             && (!('displayName' in data) || data.displayName is string)
             && (!('photoURL' in data) || data.photoURL is string)
             && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow read: if true; // Allows public leaderboard access
      
      allow create: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUserStats(incoming());
                    
      allow update: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidId(userId)
                    && isValidUserStats(incoming())
                    && incoming().diff(existing()).affectedKeys().hasAny(['good', 'bad', 'xp', 'srs', 'displayName', 'photoURL', 'updatedAt']);
                    
      allow delete: if false;
    }
  }
}
